# ============================================
# Terraform Files
# ============================================

# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform plan files
*.tfplan
tfplan
*.tfplan.*

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# ============================================
# Sensitive Files (CRITICAL!)
# ============================================

# Variable files with potential secrets
*.tfvars
*.auto.tfvars
!terraform.tfvars.example
!example.tfvars

# Any file with 'secret' or 'password' in name
**/*secret*
**/*password*
**/*key*
**/*.pem
**/*.key

# Credentials
credentials.txt
*-credentials.txt
*.creds
.env
.env.*

# Azure credentials
azure-credentials.json
azureauth.json

# ============================================
# Backup and Old Files
# ============================================

*.backup
*.bak
*.old
*.orig
*.tmp
*.temp
*~

# ============================================
# IDE & Editor Files
# ============================================

# VSCode
.vscode/
*.code-workspace

# IntelliJ IDEA
.idea/
*.iml
*.iws

# Vim
*.swp
*.swo
*~
.*.sw?

# Emacs
*~
\#*\#
.\#*

# ============================================
# OS Files
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# ============================================
# Other
# ============================================

# Logs
*.log
logs/

# Compressed files (but NOT lambda zips — they are auto-generated)
*.tar.gz
*.rar

# Lambda zip (auto-generated by Terraform archive_file — never commit)
lambda/*.zip

# Test files
*.test

# ============================================
# Private — Do NOT push to GitHub
# ============================================

# Internal documentation
EXAM-QNA.md
PROJECT-DOCUMENTATION.md
SETUP-GUIDE.md
BEFORE-YOU-DEPLOY.md
EXAM_CHECKLIST.md
TESTING_GUIDE.md

# Kubeconfig — contains cluster credentials
*.kubeconfig
kubeconfig
.kube/
